# Copie para .env e ajuste os valores antes de subir em outro ambiente.
POSTGRES_DB=consulta_tce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Porta publica da aplicacao.
APP_PORT=7113

# URL publica usada para CORS no backend.
APP_PUBLIC_ORIGIN=http://localhost:7113

# Chave compartilhada atual entre frontend publicado e backend.
# Em producao, substitua por um valor forte enquanto a protecao por header ainda existir.
FRONTEND_SECRET=ChaveLocal123!
